# PostgreSQL connection string. Required.
# Local example:  postgresql://user:password@localhost:5432/portfolio
# Replit / Neon:  use the connection string from your provider.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Initial admin password used to seed the settings drawer (CMS) on first run.
# Change this in production. After the first seed it is stored hashed in the DB.
SETTINGS_ADMIN_PASSWORD=change-me

# Optional: server bind settings (defaults shown).
PORT=5000
HOST=0.0.0.0
